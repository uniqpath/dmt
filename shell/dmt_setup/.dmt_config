#!/bin/bash

function dmt_config {

  if [ -z "$1" ]; then
    printf "${YELLOW}Usage:${NC}\n"
    echo

    printf "${GREEN}pi:${NC} sudo raspi-config\n"
    printf "${GREEN}wifi:${NC} /etc/wpa_supplicant/wpa_supplicant.conf\n"
    printf "${GREEN}net:${NC} /etc/network/interfaces\n"
    printf "${GREEN}sshd:${NC} /etc/ssh/sshd_config\n"
    printf "${GREEN}caddy:${NC} /etc/caddy/Caddyfile\n"
    printf "${GREEN}lighttpd:${NC} /etc/lighttpd/lighttpd.conf\n"
    printf "${GREEN}haproxy:${NC} /etc/haproxy/haproxy.cfg\n"
    printf "${GREEN}dnsmasq:${NC} /etc/dnsmasq.conf\n"
    printf "${GREEN}hostapd:${NC} /etc/hostapd/hostapd.conf\n"
    printf "${GREEN}alsa:${NC} /usr/share/alsa/alsa.conf\n"
    printf "${GREEN}fstab:${NC} /etc/fstab\n"
    # printf "${GREEN}mpd:${NC} /etc/mpd.conf || ~/.mpdconf\n"
    printf "${GREEN}samba:${NC} /etc/samba/smb.conf\n"
    printf "${GREEN}syncthing:${NC} ~/.config/syncthing/config.xml\n"
    printf "${GREEN}munin:${NC} /etc/munin/munin.conf\n"
    printf "${GREEN}munin-node:${NC} /etc/munin/munin-node.conf\n"
    printf "${GREEN}mosquitto:${NC} /etc/mosquitto/mosquitto.conf ${GRAY}${NC}\n"
    printf "${GREEN}mysql:${NC} /etc/mysql/mariadb.conf.d ${GRAY}${NC}\n"
    printf "${GREEN}nix:${NC} ~/.nixpkgs/darwin-configuration.nix ${GRAY}${NC}\n"

    return
  fi

  declare -a opts=(
    "caddy"
    "lighttpd"
    "sshd"
    "pi"
    "wifi"
    "net"
    "dnsmasq"
    "hostapd"
    "mosquitto"
    "ap"
    "alsa"
    "fstab"
    "samba"
    "syncthing"
    "munin"
    "munin-node"
    "mysql"
    "haproxy"
    "nix"
  )

  local matching_opt=''
  dmt_opts_matcher matching_opt "$1" "${opts[@]}"
  if [ $? -ne 0 ]; then # error
    printf "${RED}Unknown package${NC}\n"
    return
  fi

  shift

  case "$matching_opt" in
    pi)
      sudo raspi-config
      ;;

    wifi)
      wifi_setup "from_conf" "$@"
      ;;

    net)
      local conf="/etc/network/interfaces"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no networking config file found${NC}\n"
        return
      fi
      ;;

    caddy)
      local conf="/etc/caddy/Caddyfile"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no Caddy config file found${NC}\n"
        return
      fi
      ;;

    sshd)
      local conf="/etc/ssh/sshd_config"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no sshd config file found${NC}\n"
        return
      fi
      ;;

    lighttpd)
      local conf="/etc/lighttpd/lighttpd.conf"

      # readlink -- "$conf"

      local target=$(readlink -- "$conf")

      if [[ "$target" =~ ^"$HOME/.dmt/user/devices" ]]; then

        printf "⚠️  ${MAGENTA}Cannot edit this config file here because it is symlinked to ~/.dmt${NC}\n"
        printf "Symlink ${WHITE}${conf}${NC} → ${CYAN}${target}${NC}\n"
        echo
        printf "${GRAY}You should edit on your ${MAGENTA}mainDevice${NC} ${GRAY}and ${GREEN}dmt copy ${GRAY}it to this device ...${NC}\n"
        echo
      else
        if [ -f "${conf}" ]; then
          printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
          sudo nano "${conf}"
        else
          printf "${RED}no lighttpd config file found${NC}\n"
          return
        fi
      fi
      ;;

    haproxy)
      local conf="/etc/haproxy/haproxy.cfg"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no haproxy config file found${NC}\n"
        return
      fi
      ;;

    # hiawatha)
    #   local conf="/etc/hiawatha/hiawatha.conf"

    #   if [ -f "${conf}" ]; then
    #     printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
    #     sudo nano "${conf}"
    #   else
    #     printf "${RED}no hiawatha config file found${NC}\n"
    #     return
    #   fi
    #   ;;

    dnsmasq)
      local conf="/etc/dnsmasq.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no dnsmasq config file found${NC}\n"
        return
      fi
      ;;

    hostapd)
      printf "${YELLOW}Please use ${GREEN}conf ap${NC}\n"
      ;;

    ap)
      local conf="/etc/hostapd/hostapd.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no hostapd config file found${NC}\n"
        return
      fi
      ;;

    alsa)
      local conf="/usr/share/alsa/alsa.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no alsa config file found${NC}\n"
        return
      fi
      ;;

    fstab)
      local conf="/etc/fstab"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no fstab config file found${NC}\n"
        return
      fi
      ;;

    # mpd)
    #   local conf="/etc/mpd.conf"
    #   local conf2="$HOME/.mpdconf"

    #   if [ -f "${conf}" ]; then
    #     printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
    #     sudo nano "${conf}"
    #   elif [ -f "${conf2}" ]; then
    #     printf "${CYAN}Editing ${YELLOW}${conf2}${NC}\n"
    #     nano "${conf2}"
    #   else
    #     printf "${RED}no mpd config file found${NC}\n"
    #     return
    #   fi
    #   ;;

    samba)
      local conf="/etc/samba/smb.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no samba config file found${NC}\n"
      fi
      ;;

    syncthing)
      local conf="$HOME/.config/syncthing/config.xml"
      local conf2="$HOME/Library/Application Support/Syncthing/config.xml"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        nano "${conf}"
      elif [ -f "${conf2}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf2}${NC}\n"
        nano "${conf2}"
      else
        printf "${RED}no syncthing config file found${NC}\n"
      fi
      ;;

    munin)
      local conf="/etc/munin/munin.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no munin config file found${NC}\n"
      fi
      ;;

    munin-node)
      local conf="/etc/munin/munin-node.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no munin-node config file found${NC}\n"
      fi
      ;;

    mosquitto)
      local conf="/etc/mosquitto/mosquitto.conf"

      if [ -f "${conf}" ]; then
        printf "${CYAN}Editing ${YELLOW}${conf}${NC}\n"
        sudo nano "${conf}"
      else
        printf "${RED}no mosquitto config file found${NC}\n"
      fi
      ;;

    mysql)
      local conf="/etc/mysql/mariadb.conf.d"

      if [ -d "${conf}" ]; then
        printf "${CYAN}cd ${YELLOW}${conf}${NC}\n"
        cd "${conf}"
      else
        printf "${RED}no mysql/mariadb config directory found${NC}\n"
      fi
      ;;

    nix) # only for macos for now
      local conf=~/.nixpkgs/darwin-configuration.nix

      if [ -f "${conf}" ]; then
        nano "${conf}"
        printf "Install packages now — run ${GREEN}darwin-rebuild switch${NC} ?\n"
        read -r -p "[Y/n] " response
        if [[ $response =~ ^([nN])$ ]]
        then
          #printf "${GRAY}↳ Exiting ...${NC}\n"
          #echo
          return
        fi

        darwin-rebuild switch
      else
        printf "${RED}no nixos config file found${NC}\n"
      fi
      ;;

  esac
}


# SETUP THIS FIRST SO THERE IS ENOUGH PERMISSION
#
# sudo visudo (! change [your_user])
#
# ⚠️ add below %sudo   ALL=(ALL:ALL) ALL ↴
# david ALL=(ALL) NOPASSWD: /usr/bin/cp /home/[your_user]/.dmt/user/devices/this/conf/* /etc/caddy/
# david ALL=(ALL) NOPASSWD: /usr/bin/cp /home/[your_user]/.dmt/etc/conf/caddy/* /etc/caddy/
# david ALL=(ALL) NOPASSWD: /usr/bin/systemctl reload caddy
# david ALL=(ALL) NOPASSWD: /usr/bin/caddy validate --config /etc/caddy
# david ALL=(ALL) NOPASSWD: /usr/bin/caddy validate --config /home/[your_user]/.dmt/user/devices/this/conf/Caddyfile
#
# can check rule priority with: sudo -l
#
# put this in on_update script on each device: [device]/on_update
#
# Caddyfyle has to be here: [device]/conf/Caddyfile
#
function update_caddy_configuration {
  local USER="$1"
  local HOST="$2"

  local DEVICE_CONF_DIR="/home/${USER}/.dmt/user/devices/this/conf"
  local SOURCE_CADDY_FILE="${DEVICE_CONF_DIR}/Caddyfile"
  local WARNING_FILE="/home/${USER}/.dmt/etc/conf/caddy/DMT_WARNING.txt"
  local DEST="/etc/caddy/Caddyfile"
  local DEST_DIR="/etc/caddy/"

  # 1. Check if hostname is correct
  if [ "$(hostname)" = "${HOST}" ]; then

      # 2. Check if source file exist and caddy is present
      if [ -f "$SOURCE_CADDY_FILE" ] && [ -d "$DEST_DIR" ]; then

          # 3. Compare the files (-s flag makes cmp silent)
          if cmp -s "$SOURCE_CADDY_FILE" "$DEST"; then
              echo "Caddyfile is already up to date. No reload needed."
          else
              echo "Changes detected. Updating and reloading Caddy..."

              # 4. Validate and capture only the error line
              # 2>&1 merges stderr into stdout so we can 'grep' it
              ERROR_MSG=$(sudo /usr/bin/caddy validate --config "$SOURCE_CADDY_FILE" 2>&1 | grep "Error:")

              # 4. Validate before reloading to prevent downtime
              #if sudo caddy validate --config "$SOURCE_CADDY_FILE" >/dev/null 2>&1; then
              if [ -z "$ERROR_MSG" ]; then
                  sudo cp "$SOURCE_CADDY_FILE" "$DEST_DIR"
                  sudo systemctl reload caddy
                  echo "Caddy reloaded successfully."
              else
                  ERR="Error: New Caddyfile is invalid! ${ERROR_MSG}"
                  echo "${ERR}"
                  push_notify_high_priority "${ERR}"
                  exit 1
              fi

              echo "$WARNING_FILE" > /tmp/ok.txt

              if [ -f "$WARNING_FILE" ]; then
                sudo cp "$WARNING_FILE" "$DEST_DIR"
              fi
          fi

      else
          echo "Error: Source or Destination file missing."
          exit 1
      fi

  else
      echo "Skipping: Wrong host."
  fi
}
